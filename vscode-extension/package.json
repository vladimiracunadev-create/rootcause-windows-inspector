{
  "name": "rootcause-inspector",
  "displayName": "RootCause Windows Inspector",
  "description": "Estado del sistema Windows en la barra de estado de VS Code. Muestra severidad, CPU, RAM e I/O en tiempo real.",
  "version": "0.7.0",
  "publisher": "vladimiracunadev-create",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "icon": "icons/rootcause.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/vladimiracunadev-create/rootcause-landing"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "rootcause.refresh",
        "title": "RootCause: Actualizar estado del sistema"
      },
      {
        "command": "rootcause.export",
        "title": "RootCause: Exportar snapshot a JSON"
      },
      {
        "command": "rootcause.openPanel",
        "title": "RootCause: Abrir panel de diagnóstico"
      }
    ],
    "configuration": {
      "title": "RootCause Inspector",
      "properties": {
        "rootcause.executablePath": {
          "type": "string",
          "default": "rootcause",
          "description": "Ruta al ejecutable rootcause.exe. Usa 'rootcause' si está en el PATH."
        },
        "rootcause.refreshIntervalSeconds": {
          "type": "number",
          "default": 15,
          "minimum": 5,
          "maximum": 120,
          "description": "Intervalo de actualización del estado en segundos."
        },
        "rootcause.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Mostrar el indicador de estado en la barra inferior de VS Code."
        },
        "rootcause.alertOnCritical": {
          "type": "boolean",
          "default": true,
          "description": "Mostrar notificación cuando el sistema pase a estado Crítico."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
